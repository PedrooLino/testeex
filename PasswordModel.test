

const PasswordModel = require("../src/model/PasswordModel");

describe("PasswordModel — Regras de Validação", () => {
  let model;

  beforeEach(() => {
    model = new PasswordModel();
  });

  // ─── Regra 1: Comprimento mínimo ───────────────────────────────────────────
  describe("Regra: Mínimo de 8 caracteres", () => {
    test("deve rejeitar senha com menos de 8 caracteres", () => {
      const { isValid, errors } = model.validate("Ab1@xyz");
      expect(isValid).toBe(false);
      expect(errors).toContain("Mínimo de 8 caracteres");
    });

    test("deve aceitar senha com exatamente 8 caracteres válidos", () => {
      const { results } = model.validate("Ab1@xyzW");
      const rule = results.find((r) => r.id === "minLength");
      expect(rule.passed).toBe(true);
    });

    test("deve aceitar senha com mais de 8 caracteres", () => {
      const { results } = model.validate("Ab1@xyzWQQQ");
      const rule = results.find((r) => r.id === "minLength");
      expect(rule.passed).toBe(true);
    });
  });

  // ─── Regra 2: Letra maiúscula ───────────────────────────────────────────────
  describe("Regra: Pelo menos uma letra maiúscula", () => {
    test("deve rejeitar senha sem letra maiúscula", () => {
      const { isValid, errors } = model.validate("ab1@xyzw");
      expect(isValid).toBe(false);
      expect(errors).toContain("Pelo menos uma letra maiúscula");
    });

    test("deve aceitar senha com pelo menos uma letra maiúscula", () => {
      const { results } = model.validate("Ab1@xyzw");
      const rule = results.find((r) => r.id === "hasUppercase");
      expect(rule.passed).toBe(true);
    });
  });

  // ─── Regra 3: Letra minúscula ───────────────────────────────────────────────
  describe("Regra: Pelo menos uma letra minúscula", () => {
    test("deve rejeitar senha sem letra minúscula", () => {
      const { isValid, errors } = model.validate("AB1@XYZW");
      expect(isValid).toBe(false);
      expect(errors).toContain("Pelo menos uma letra minúscula");
    });

    test("deve aceitar senha com pelo menos uma letra minúscula", () => {
      const { results } = model.validate("Ab1@XYZW");
      const rule = results.find((r) => r.id === "hasLowercase");
      expect(rule.passed).toBe(true);
    });
  });

  // ─── Regra 4: Número ────────────────────────────────────────────────────────
  describe("Regra: Pelo menos um número", () => {
    test("deve rejeitar senha sem número", () => {
      const { isValid, errors } = model.validate("Ab!@xyzw");
      expect(isValid).toBe(false);
      expect(errors).toContain("Pelo menos um número");
    });

    test("deve aceitar senha com pelo menos um número", () => {
      const { results } = model.validate("Ab1@xyzw");
      const rule = results.find((r) => r.id === "hasNumber");
      expect(rule.passed).toBe(true);
    });
  });

  // ─── Regra 5: Caractere especial ────────────────────────────────────────────
  describe("Regra: Pelo menos um caractere especial", () => {
    test("deve rejeitar senha sem caractere especial", () => {
      const { isValid, errors } = model.validate("Ab1xyzwQ");
      expect(isValid).toBe(false);
      expect(errors).toContain("Pelo menos um caractere especial (!@#$%^&*)");
    });

    test("deve aceitar senha com caractere especial @", () => {
      const { results } = model.validate("Ab1@xyzw");
      const rule = results.find((r) => r.id === "hasSpecial");
      expect(rule.passed).toBe(true);
    });

    test("deve aceitar senha com caractere especial !", () => {
      const { results } = model.validate("Ab1!xyzw");
      const rule = results.find((r) => r.id === "hasSpecial");
      expect(rule.passed).toBe(true);
    });

    test("deve aceitar senha com caractere especial #", () => {
      const { results } = model.validate("Ab1#xyzw");
      const rule = results.find((r) => r.id === "hasSpecial");
      expect(rule.passed).toBe(true);
    });
  });

  // ─── Regra 6: Sem espaços ────────────────────────────────────────────────────
  describe("Regra: Não pode conter espaços em branco", () => {
    test("deve rejeitar senha com espaço no meio", () => {
      const { isValid, errors } = model.validate("Ab1@ xyz");
      expect(isValid).toBe(false);
      expect(errors).toContain("Não pode conter espaços em branco");
    });

    test("deve rejeitar senha com espaço no início", () => {
      const { isValid, errors } = model.validate(" Ab1@xyz");
      expect(isValid).toBe(false);
      expect(errors).toContain("Não pode conter espaços em branco");
    });

    test("deve rejeitar senha com espaço no final", () => {
      const { isValid, errors } = model.validate("Ab1@xyz ");
      expect(isValid).toBe(false);
      expect(errors).toContain("Não pode conter espaços em branco");
    });

    test("deve aceitar senha sem espaços", () => {
      const { results } = model.validate("Ab1@xyzw");
      const rule = results.find((r) => r.id === "noSpaces");
      expect(rule.passed).toBe(true);
    });
  });

  // ─── Cenários combinados ─────────────────────────────────────────────────────
  describe("Cenários combinados", () => {
    test("deve aprovar senha completamente válida", () => {
      const { isValid, errors } = model.validate("Senh@F0rte!");
      expect(isValid).toBe(true);
      expect(errors).toHaveLength(0);
    });

    test("deve retornar múltiplos erros para senha fraca", () => {
      const { isValid, errors } = model.validate("abc");
      expect(isValid).toBe(false);
      expect(errors.length).toBeGreaterThan(1);
    });

    test("deve retornar o resultado de todas as 6 regras", () => {
      const { results } = model.validate("Senh@F0rte!");
      expect(results).toHaveLength(6);
    });
  });

  // ─── Força da senha ──────────────────────────────────────────────────────────
  describe("getStrength — Cálculo de força", () => {
    test("deve retornar 0 para senha vazia", () => {
      expect(model.getStrength("")).toBe(0);
    });

    test("deve retornar 100 para senha que passa em todas as regras", () => {
      expect(model.getStrength("Senh@F0rte!")).toBe(100);
    });

    test("deve retornar valor proporcional ao número de regras atendidas", () => {
      // "abcdefg" → apenas minúscula + sem espaços = 2/6 ≈ 33%
      const strength = model.getStrength("abcdefg");
      expect(strength).toBeGreaterThan(0);
      expect(strength).toBeLessThan(100);
    });
  });

  // ─── Tratamento de entrada inválida ─────────────────────────────────────────
  describe("Tratamento de entrada inválida", () => {
    test("deve lançar TypeError para entrada não-string (número)", () => {
      expect(() => model.validate(12345678)).toThrow(TypeError);
    });

    test("deve lançar TypeError para entrada nula", () => {
      expect(() => model.validate(null)).toThrow(TypeError);
    });

    test("deve lançar TypeError para entrada undefined", () => {
      expect(() => model.validate(undefined)).toThrow(TypeError);
    });
  });
});
